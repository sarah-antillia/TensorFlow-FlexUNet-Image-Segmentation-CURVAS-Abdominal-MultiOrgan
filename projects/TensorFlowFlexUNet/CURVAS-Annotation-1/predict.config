; train_eval_infer.config
; 2026/03/31 (C) antillia.com
; compare.config
[model]
model         = "TensorFlowFlexUNet"
generator     =  False

image_width    = 512
image_height   = 512
image_channels = 3
input_normalize = True
normalization  = False
num_classes    = 4
base_filters   = 16
base_kernels   = (11,11)
num_layers     = 8
dropout_rate   = 0.05
dilation       = (1,1)

; Model compilation parameters
optimizer       = "Adam"

learning_rate  = 0.00007
clipvalue      = 0.5

; Specify "categorical_crossentropy" function to loss
; for categoraized(one-hot-encoded) mask 
loss           = "categorical_crossentropy"
metrics        = ["dice_coef_multiclass"]

show_summary   = False

[dataset]
class_name    = "ImageCategorizedMaskDataset"

[train]
;epochs       = 100
epochs        = 60
batch_size    = 2

;steps_per_epoch  = 200
;validation_steps = 80

; EarlyStopping parameter
patience      = 10

metrics       = ["dice_coef_multiclass", "val_dice_coef_multiclass"]

model_dir     = "./models/"
eval_dir      = "./eval/"
images_dir    = "../../../dataset/CURVAS-Annotation-1/train/images/"
masks_dir     = "../../../dataset/CURVAS-Annotation-1/train/masks/"

create_backup  = False

; learning_rate_reducer callback parameter
learning_rate_reducer = True
reducer_factor     = 0.4
reducer_patience   = 4

; Model saving option
save_weights_only  = True

[valid]
images_dir = "../../../dataset/CURVAS-Annotation-1/valid/images/"
masks_dir  = "../../../dataset/CURVAS-Annotation-1/valid/masks/"

[test] 
images_dir = "../../../dataset/CURVAS-Annotation-1/test/images/"
masks_dir  = "../../../dataset/CURVAS-Annotation-1/test/masks/"

[infer] 
images_dir    = "./compare/images/"
output_dir    = "./compare_output/"

[image]
color_order = "RGB"

[mask]
mask_datatyoe    = "categorized"
mask_file_format = ".png"
;CURVAS-Annotation-1 rgb color map dict for 1+3 classes.
;                      pancreas ,     kidney,        liver
rgb_map = {(0,0,0):0, (0,255,255):1, (255,255,0):2, (255, 0,255):3 }


